# ============================================================
# Chat Room Admin Panel — Environment Variables
# ============================================================
# 复制为 .env 并填入真实值:
#   cp .env.example .env

# --- Flask ---
SECRET_KEY=

# --- MySQL（连接到与主聊天室相同的数据库）---
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DB=chatroom
MYSQL_USER=chatroom
MYSQL_PASSWORD=

# --- Server ---
ADMIN_PORT=9889
FLASK_DEBUG=0
